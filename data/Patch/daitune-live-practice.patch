+
+/* ===================== Live practice (microphone) ===================== */
+
+.mic-pill .mic-status {
+  margin-left: 10px;
+  font-size: 12px;
+  font-weight: 700;
+  padding: 3px 9px;
+  border-radius: 999px;
+  background: rgba(255, 255, 255, 0.14);
+  color: #f3f6ff;
+  min-width: 46px;
+  text-align: center;
+}
+
+.mic-pill .mic-status-listening {
+  background: rgba(52, 211, 153, 0.22);
+  color: #b8f7dd;
+}
+
+.mic-pill .mic-status-denied {
+  background: rgba(248, 113, 113, 0.22);
+  color: #ffd2d2;
+}
+
+.practice-stats {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  padding: 6px 12px;
+  border-radius: 999px;
+  background: rgba(10, 14, 34, 0.55);
+  border: 1px solid rgba(255, 255, 255, 0.14);
+}
+
+.practice-stat {
+  font-size: 12.5px;
+  font-weight: 800;
+  letter-spacing: 0.02em;
+}
+
+.practice-stat.hit { color: #6ef0b7; }
+.practice-stat.miss { color: #ffd47e; }
+.practice-stat.wrong { color: #ff9c9c; }
+
+.practice-stat.accuracy {
+  color: #eef2ff;
+  padding-left: 8px;
+  border-left: 1px solid rgba(255, 255, 255, 0.2);
+}
+
+.piano-key.live-detected {
+  box-shadow:
+    inset 0 -4px 0 rgba(52, 211, 153, 0.95),
+    0 0 14px rgba(52, 211, 153, 0.55);
+}
+
+.piano-key.black-key.live-detected {
+  box-shadow:
+    inset 0 -3px 0 rgba(52, 211, 153, 0.95),
+    0 0 12px rgba(52, 211, 153, 0.6);
+}
+
+.piano-key.wrong-flash {
+  animation: wrongKeyFlash 0.45s ease-out;
+  box-shadow:
+    inset 0 -4px 0 rgba(248, 82, 82, 0.95),
+    0 0 16px rgba(248, 82, 82, 0.6);
+}
+
+@keyframes wrongKeyFlash {
+  0% { filter: brightness(1.9) saturate(1.4); }
+  100% { filter: brightness(1) saturate(1); }
+}
+
+/* ===================== SheetView (real grand staff) ===================== */
+
+.sheetview-card {
+  position: relative;
+  margin: 14px 18px 10px;
+  border-radius: 18px;
+  background: linear-gradient(180deg, #fdfcff 0%, #f4f2fb 100%);
+  border: 1px solid rgba(120, 105, 180, 0.22);
+  box-shadow: 0 14px 34px rgba(20, 16, 60, 0.24);
+  overflow: hidden;
+  cursor: pointer;
+  flex: 1 1 auto;
+  min-height: 300px;
+}
+
+.sheetview-card--compact {
+  flex: 0 0 auto;
+  min-height: 208px;
+}
+
+.sheetview-svg {
+  display: block;
+}
+
+.sheetview-staff-line {
+  stroke: rgba(38, 34, 72, 0.55);
+  stroke-width: 1;
+}
+
+.sheetview-system-line {
+  stroke: rgba(38, 34, 72, 0.75);
+  stroke-width: 2.4;
+}
+
+.sheetview-ledger-line {
+  stroke: rgba(38, 34, 72, 0.7);
+  stroke-width: 1.1;
+}
+
+.sheetview-grid-line {
+  stroke: rgba(90, 82, 150, 0.14);
+  stroke-width: 1;
+}
+
+.sheetview-grid-line.strong {
+  stroke: rgba(90, 82, 150, 0.3);
+}
+
+.sheetview-grid-label {
+  font: 700 10px Inter, system-ui, sans-serif;
+  fill: rgba(70, 62, 120, 0.6);
+}
+
+.sheetview-clef-backdrop {
+  fill: rgba(250, 248, 255, 0.92);
+}
+
+.sheetview-clef {
+  font-size: 46px;
+  fill: #262248;
+}
+
+.sheetview-clef-bass {
+  font-size: 38px;
+}
+
+.sheetview-hand-tag {
+  font: 800 10px Inter, system-ui, sans-serif;
+  letter-spacing: 0.08em;
+}
+
+.sheetview-hand-tag.right { fill: #c2418f; }
+.sheetview-hand-tag.left { fill: #1f7fd1; }
+
+.sheetview-accidental {
+  font: 800 13px Georgia, "Times New Roman", serif;
+  fill: #262248;
+}
+
+.sheetview-note-label {
+  font: 800 11px Inter, system-ui, sans-serif;
+  fill: #262248;
+  text-anchor: middle;
+}
+
+.sheetview-active-ring {
+  fill: none;
+  stroke: rgba(124, 92, 255, 0.85);
+  stroke-width: 2;
+}
+
+.sheetview-note.is-active .sheetview-note-head {
+  filter: drop-shadow(0 0 5px rgba(124, 92, 255, 0.65));
+}
+
+.sheetview-judgement-mark {
+  font: 900 11px Inter, system-ui, sans-serif;
+  text-anchor: middle;
+}
+
+.sheetview-judgement-mark.hit { fill: #128a5f; }
+.sheetview-judgement-mark.miss { fill: #c23a3a; }
+
+.sheetview-playhead {
+  stroke: rgba(124, 92, 255, 0.9);
+  stroke-width: 2.4;
+  filter: drop-shadow(0 0 6px rgba(124, 92, 255, 0.55));
+}
+
+.sheetview-playhead-cap {
+  fill: rgba(124, 92, 255, 0.95);
+}
+
+.view-mode-sheet .lesson-stage,
+.lesson-stage.view-mode-sheet {
+  display: flex;
+  flex-direction: column;
+}
