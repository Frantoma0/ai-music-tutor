+
+/* ============================================================= */
+/* ====================  Practice Coach  ======================= */
+/* ============================================================= */
+
+.coach-pill {
+  cursor: pointer;
+  border: 1.4px solid var(--surface-border, rgba(179, 166, 228, 0.42));
+  gap: 7px;
+  display: inline-flex;
+  align-items: center;
+}
+
+.coach-pill:hover { transform: translateY(-1px); }
+.coach-pill-icon { font-size: 15px; }
+
+.coach-overlay {
+  position: absolute;
+  inset: 0;
+  z-index: 34;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: rgba(6, 8, 22, 0.55);
+  backdrop-filter: blur(3px);
+}
+
+.coach-card {
+  width: min(560px, 92%);
+  max-height: 86%;
+  overflow-y: auto;
+  border-radius: 22px;
+  background: var(--surface-strong, rgba(255, 255, 255, 0.96));
+  border: 1px solid var(--surface-border, rgba(179, 166, 228, 0.42));
+  box-shadow: 0 26px 70px rgba(10, 8, 40, 0.5);
+  padding: 18px;
+  color: var(--text-primary);
+  display: flex;
+  flex-direction: column;
+  gap: 12px;
+}
+
+.coach-card-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  font-size: 15.5px;
+}
+
+.coach-status {
+  margin: 4px 0 8px;
+  color: var(--text-secondary);
+  font-size: 14px;
+}
+
+.coach-overall-tip {
+  margin: 0;
+  font-size: 14px;
+  font-weight: 600;
+  line-height: 1.45;
+}
+
+.coach-recommended-row {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  flex-wrap: wrap;
+  font-size: 12.5px;
+  font-weight: 700;
+  color: var(--text-secondary);
+}
+
+.coach-chip {
+  padding: 6px 11px;
+  border-radius: 999px;
+  border: 1.3px solid var(--surface-border, rgba(179, 166, 228, 0.42));
+  background: var(--surface-soft, rgba(255, 255, 255, 0.5));
+  color: var(--text-primary);
+  font-weight: 800;
+  font-size: 12px;
+  cursor: pointer;
+}
+
+.coach-chip:hover {
+  background: var(--switch-active-bg, #7a6ef0);
+  color: var(--switch-active-text, #fff);
+}
+
+.coach-sections {
+  display: flex;
+  flex-direction: column;
+  gap: 9px;
+}
+
+.coach-section {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 11px 13px;
+  border-radius: 16px;
+  background: var(--surface-soft, rgba(255, 255, 255, 0.5));
+  border: 1px solid var(--surface-border, rgba(179, 166, 228, 0.42));
+}
+
+.coach-section-main {
+  display: flex;
+  flex-direction: column;
+  gap: 3px;
+  min-width: 0;
+  flex: 1;
+}
+
+.coach-section-main strong {
+  font-size: 14px;
+  font-variant-numeric: tabular-nums;
+}
+
+.coach-section-meta {
+  font-size: 12px;
+  font-weight: 700;
+  color: var(--text-secondary);
+}
+
+.coach-section-tip {
+  font-size: 12.5px;
+  line-height: 1.4;
+  color: var(--text-primary);
+}
+
+.coach-practice-button {
+  flex: 0 0 auto;
+  padding: 9px 14px;
+  border-radius: 999px;
+  border: none;
+  background: var(--switch-active-bg, #7a6ef0);
+  color: var(--switch-active-text, #fff);
+  font-weight: 800;
+  font-size: 12.5px;
+  cursor: pointer;
+}
+
+.coach-practice-button:hover { filter: brightness(1.08); }
+
+/* ============================================================= */
+/* =====================  RESPONSIVE  ========================== */
+/* ============================================================= */
+
+/* Controls footer: one scrollable row on every size */
+.controls-card {
+  flex-wrap: nowrap !important;
+  overflow-x: auto !important;
+  -webkit-overflow-scrolling: touch;
+  scrollbar-width: thin;
+}
+
+.controls-card > * {
+  flex: 0 0 auto !important;
+}
+
+@media (max-width: 1024px) {
+  .top-player-bar {
+    flex-wrap: wrap !important;
+    gap: 8px !important;
+    padding: 10px 12px !important;
+  }
+
+  .lesson-player-bar {
+    order: 10;
+    width: 100% !important;
+  }
+
+  .view-switch button {
+    padding: 7px 10px !important;
+    font-size: 12px !important;
+  }
+
+  .waterfall-frame {
+    height: clamp(300px, 46vh, 540px) !important;
+    min-height: 300px !important;
+  }
+
+  .home-app-header {
+    flex-wrap: wrap !important;
+    gap: 10px !important;
+  }
+
+  .home-lessons-grid {
+    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)) !important;
+    gap: 12px !important;
+  }
+
+  .settings-panel {
+    top: 10px !important;
+    right: 10px !important;
+    bottom: 10px !important;
+    width: min(360px, calc(100vw - 20px)) !important;
+  }
+
+  .sessions-drawer {
+    width: min(92vw, 350px) !important;
+  }
+}
+
+@media (max-width: 640px) {
+  .piano-keyboard {
+    height: 96px !important;
+  }
+
+  .white-key-label,
+  .black-label {
+    display: none !important;
+  }
+
+  .mini-control-pill {
+    padding: 6px 10px !important;
+  }
+
+  .mini-mode-switch button {
+    padding: 6px 9px !important;
+    font-size: 11.5px !important;
+  }
+
+  .lesson-title {
+    font-size: 16px !important;
+    max-width: 52vw !important;
+  }
+
+  .waterfall-frame {
+    height: clamp(240px, 42vh, 420px) !important;
+    min-height: 240px !important;
+  }
+
+  .countdown-number {
+    font-size: 76px !important;
+  }
+
+  .results-card,
+  .coach-card {
+    width: 94% !important;
+    padding: 14px !important;
+  }
+
+  .coach-section {
+    flex-direction: column;
+    align-items: stretch;
+  }
+
+  .coach-practice-button {
+    width: 100%;
+  }
+
+  .sheetview-card {
+    margin: 8px 6px !important;
+    min-height: 200px !important;
+  }
+
+  .home-lessons-grid {
+    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)) !important;
+  }
+
+  .home-hero-card {
+    flex-direction: column !important;
+  }
+
+  .theme-swatch-row {
+    grid-template-columns: repeat(3, 1fr);
+  }
+}
+
+@media (max-width: 420px) {
+  .piano-keyboard {
+    height: 84px !important;
+  }
+
+  .view-switch .view-switch-label,
+  .view-switch button span:last-child {
+    display: none;
+  }
+}
