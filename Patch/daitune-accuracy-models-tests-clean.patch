+  .filter((name) => name.endsWith(".mjs"))
+  .map((name) => path.join(outDir, name));
+
+const result = spawnSync(process.execPath, ["--test", ...bundledTests], {
+  stdio: "inherit",
+});
+
+process.exit(result.status ?? 1);
